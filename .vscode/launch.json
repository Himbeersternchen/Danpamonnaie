  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run parse_invoice_letter.process_purpose as module",
      "type": "debugpy",
      "request": "launch",
      "module": "parse_invoice_letter.process_purpose",
      "justMyCode": true, // Only debug my project’s Python files, skip the libraries.
      "cwd": "${workspaceFolder}/backend",
      "console": "integratedTerminal"
    },
    {
      "name": "Run parse_invoice_letter.utils.find_unmatched_descriptions as module",
      "type": "debugpy",
      "request": "launch",
      "module": "parse_invoice_letter.utils.find_unmatched_descriptions",
      "justMyCode": true, // Only debug my project’s Python files, skip the libraries.
      "cwd": "${workspaceFolder}/backend",
      "console": "integratedTerminal"
    },
    {
      "name": "Run parse_invoice_letter.read_invoice_csv as module",
      "type": "debugpy",
      "request": "launch",
      "module": "parse_invoice_letter.read_invoice_csv",
      "justMyCode": true, // Only debug my project’s Python files, skip the libraries.
      "cwd": "${workspaceFolder}/backend",
      "console": "integratedTerminal"
    },
    {
      "name": "Run parse_invoice_letter.process_bank as module",
      "type": "debugpy",
      "request": "launch",
      "module": "parse_invoice_letter.process_bank",
      "justMyCode": true, // Only debug my project’s Python files, skip the libraries.
      "cwd": "${workspaceFolder}/backend",
      "console": "integratedTerminal"
    },
    {
      "name": "Python Debugger: Django",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/backend/manage.py",
      "args": ["runserver", "8002"],
      "django": true,
      "justMyCode": true
    },
    {
      "name": "Debug Frontend (npm)",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
